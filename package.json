{
  "name": "@adaptive-ds/convex-auth-solid",
  "version": "0.1.0",
  "scripts": {
    "cc": "clear && bun run convex codegen",
    "t": "clear && bun run tsc",
    "type-check": "bun run tsc",
    "deploy": "bun run backend:deploy && bun run frontend:deploy",
    "frontend:deploy": "bun run rsbuild:deploy",
    "frontend:upload": "bun run wrangler pages deploy ./dist --commit-dirty=true --project-name=dcc-app",
    "frontend:tag": "git branch -f frontend",
    "dev": "bun run rsbuild:dev",
    "vite:dev": "bun run vite:clean && clear && nice -5 vite dev --debug hmr",
    "vite:build": "nice -15 vite build",
    "vite:deploy": "bun run vite:build && bun run frontend:upload && bun run frontend:tag",
    "vite:clean": "rm -rf ./node_modules/.vite/deps",
    "vite:preview": "nice -5 vite preview",
    "build": "bun run rsbuild:build",
    "rsbuild:dev": "nice -5 rsbuild dev",
    "rsbuild:build": "nice -15 rsbuild build",
    "rsbuild:deploy": "bun run rsbuild:build && bun run frontend:upload && bun run frontend:tag",
    "rsbuild:clean": "rm -rf node_modules/.cache",
    "format": "prettier --write --cache \"{convex,functions,src,test,ui}/**/*.{astro,js,jsx,ts,tsx}\"",
    "test": "bun test",
    "test:w": "bun test --watch",
    "backend:deploy": "bun run convex:deploy && bun run backend:tag",
    "backend:tag": "git branch -f backend",
    "convex:dev": "bash ops/convex_dev/convex_dev.bash",
    "convex:dev:dev": "export CI=1 && clear && convex dev --local",
    "convex:dev:test": "export CI=1 && convex dev --local --once",
    "convex:test": "export CI=1 && convex dev --local --once",
    "convex:docker:pull": "bash ops/convex_dev/convex_docker_up.bash",
    "convex:docker:up": "bash ops/convex_dev/convex_docker_up.bash",
    "convex:docker:up:d": "bash ops/convex_dev/convex_docker_up.bash -d",
    "convex:docker:down": "bash ops/convex_dev/convex_docker_down.bash",
    "convex:docker:update": "bash ops/convex_dev/convex_docker_update.bash",
    "convex:deploy": "bash ops/convex_prod/convex_deploy_prod.bash",
    "ui": "rsync -avh --delete ../solid-ui/ui/ ./ui/",
    "ui:push": "rsync -avh --delete ./ui/  ../adaptive/solid-ui/ui/",
    "generateDemoList": "bun run ./src/app/demos/generateDemoList.cli.ts",
    "generateTranslations": "bun run ./src/app/i18n/generateTranslations.ts",
    "update": "bun x npm-check-updates -u && bun i",
    "update:commit": "bun x npm-check-updates -u && bun i && git add package.json && bun run tsc && git commit -m \"chore(deps): update dependencies\" && git push",
    "clean": "rm -rf ./dist",
    "reset": "rm -rf ./node_modules"
  },
  "dependencies": {
    "@adaptive-ds/email-generator": "^0.11.0",
    "@adaptive-ds/result": "^0.5.0",
    "@adaptive-ds/solid-ui": "^0.13.1",
    "@adaptive-ds/utils": "^0.13.0",
    "@bradenmacdonald/s3-lite-client": "^0.9.5",
    "@corvu/dialog": "^0.2.4",
    "@corvu/popover": "^0.2.0",
    "@floating-ui/dom": "^1.7.6",
    "@mdi/js": "^7.4.47",
    "@solid-primitives/keyed": "^1.5.3",
    "@solid-primitives/scheduled": "^1.5.3",
    "@solidjs/router": "^0.15.4",
    "clsx": "^2.1.1",
    "convex": "^1.33.1",
    "dayjs": "^1.11.20",
    "jose": "^6.2.1",
    "jwt-decode": "^4.0.0",
    "posthog-js": "^1.360.2",
    "solid-js": "1.9.11",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@rsbuild/core": "^1.7.3",
    "@rsbuild/plugin-babel": "^1.1.2",
    "@rsbuild/plugin-node-polyfill": "^1.4.4",
    "@rsbuild/plugin-solid": "^1.1.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/bun": "latest",
    "autoprefixer": "^10.4.27",
    "glob": "^13.0.6",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "ts-morph": "^27.0.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-solid": "^2.11.11",
    "wrangler": "^4.73.0"
  },
  "imports": {
    "#convex/*": "./convex/*",
    "#src/*.js": "./src/*.ts",
    "#src/*.jsx": "./src/*.tsx",
    "#src/*": "./src/*",
    "#ui/*.js": "./ui/*.ts",
    "#ui/*.jsx": "./ui/*.tsx",
    "#ui/*": "./ui/*",
    "#utils/*": "@adaptive-ds/utils/*",
    "#result": "@adaptive-ds/result",
    "#result/*": "@adaptive-ds/result/*"
  },
  "prettier": {
    "semi": false,
    "printWidth": 120,
    "trailingComma": "all"
  },
  "type": "module",
  "private": false,
  "license": "MIT",
  "homepage": "https://github.com/david1gp/convex-auth-solid",
  "description": "Build authenticated SolidJS apps lightning-fast with Convex",
  "keywords": [
    "convex",
    "authentication",
    "auth",
    "solidjs",
    "solid-js",
    "ui-components",
    "reactive",
    "frontend",
    "adaptive",
    "login",
    "signup",
    "session",
    "convex-backend",
    "convex-auth",
    "jwt"
  ],
  "repository": {
    "url": "git+https://github.com/david1gp/convex-auth-solid.git"
  },
  "exports": {
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "files": [
    "dist"
  ]
}
